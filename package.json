{
  "name": "jira-github-work-dashboard",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "api:dev": "node --watch api/main.ts",
    "dev": "vite",
    "db:migrate": "node api/migrate.ts",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test:watch": "vitest",
    "check": "npm run test:typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.0.0",
    "fastify": "^5.8.5",
    "lucide-react": "^0.468.0",
    "pg": "^8.21.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@types/pg": "^8.20.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.6.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.8"
  }
}
