# Restart the dashboard container after changing these values.
JIRA_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=
# Optional. Empty means every active assigned project visible to the token.
#JIRA_PROJECT_KEYS=APP,OPS

GITHUB_TOKEN=
GITHUB_USERNAME=
# Optional GitHub search qualifiers: org:example,repo:owner/name
#GITHUB_SEARCH_SCOPES=

# Optional. Empty derives prefixes from the Jira tickets returned.
#TICKET_KEY_PREFIXES=APP,OPS

# Optional comma-separated Jira status names. Empty groups use generic defaults.
#WORKFLOW_BACKLOG_STATUSES=Backlog,Open,Ready,To Do
#WORKFLOW_DEVELOPMENT_STATUSES=Development,In Progress
#WORKFLOW_CODE_REVIEW_STATUSES=Code Review,In Review
#WORKFLOW_TESTING_STATUSES=Testing,In QA
#WORKFLOW_RELEASE_STATUSES=Ready for Release,Ready for Production
#WORKFLOW_FINALIZED_STATUSES=Done,Closed,Released

#Local PostgreSQL container.
POSTGRES_DB=ticketdash
POSTGRES_USER=ticketdash
POSTGRES_PASSWORD=ticketdash
